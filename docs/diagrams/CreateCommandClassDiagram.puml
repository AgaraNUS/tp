@startuml CreateCommandClassDiagram
skinparam classAttributeIconSize 0
skinparam style strictuml

interface Command {
    +execute(StudentDatabase, Storage): CommandResult
    +undo(StudentDatabase, Storage): CommandResult
    +isUndoable(): boolean
}

class CreateCommand {
    -name: String
    -phone: String
    -email: String
    -address: String
    -course: String
    -createdIndex: int
    +CreateCommand(String, String, String, String, String)
    +execute(StudentDatabase, Storage): CommandResult
    +undo(StudentDatabase, Storage): CommandResult
    +isUndoable(): boolean
}

class StudentDatabase {
    +addStudent(Student): void
    +removeStudent(int): Student
    +getStudentCount(): int
}

class Storage {
    +saveStudentList(StudentDatabase): void
}

class Student {
    +getName(): String
}

class "Student.Builder" as Builder {
    +Builder(String)
    +phone(String): Builder
    +email(String): Builder
    +address(String): Builder
    +course(String): Builder
    +build(): Student
}

class CommandResult {
    -message: String
    -exit: boolean
    +getMessage(): String
    +shouldExit(): boolean
}

Command <|.. CreateCommand
CreateCommand ..> StudentDatabase : uses
CreateCommand ..> Storage : uses
CreateCommand ..> Builder : uses
CreateCommand ..> CommandResult : creates
Builder ..> Student : builds
@enduml
